local bodyGyro = nil
local bodyVelocity = nil
local flyConnection = nil

local function startMobileFly(speed)
    if States.flying then return end
    
    local char = getCharacter()
    local root = getRootPart()
    local humanoid = getHumanoid()
    
    if not root or not humanoid then
        addConsole("❌ Ошибка: персонаж не найден", Color3.fromRGB(255, 0, 0))
        return
    end
    
    States.flying = true
    States.flySpeed = speed or 50
    
    -- Очищаем старые объекты
    if bodyGyro then bodyGyro:Destroy() end
    if bodyVelocity then bodyVelocity:Destroy() end
    
    -- Создаем BodyGyro
    bodyGyro = Instance.new("BodyGyro")
    bodyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
    bodyGyro.P = 100000
    bodyGyro.D = 1000
    bodyGyro.CFrame = root.CFrame
    bodyGyro.Parent = root
    
    -- Создаем BodyVelocity
    bodyVelocity = Instance.new("BodyVelocity")
    bodyVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    bodyVelocity.P = 100000
    bodyVelocity.Velocity = Vector3.zero
    bodyVelocity.Parent = root
    
    -- Открепляем персонажа
    root.Anchored = false
    humanoid.PlatformStand = true
    
    -- Показываем элементы управления
    JoystickFrame.Visible = true
    UpButton.Visible = true
    DownButton.Visible = true
    
    -- Основной цикл полета
    if flyConnection then flyConnection:Disconnect() end
    flyConnection = runService.RenderStepped:Connect(function()
        if not States.flying then return end
        
        local currentRoot = getRootPart()
        if not currentRoot or not bodyGyro or not bodyVelocity then return end
        
        -- Обновляем родителя если персонаж изменился
        if bodyGyro.Parent ~= currentRoot then
            bodyGyro.Parent = currentRoot
        end
        if bodyVelocity.Parent ~= currentRoot then
            bodyVelocity.Parent = currentRoot
        end
        
        local camera = workspace.CurrentCamera
        if not camera then return end
        
        -- Направление всегда по камере
        bodyGyro.CFrame = camera.CFrame
        
        -- Расчет движения
        local moveVector = Vector3.zero
        
        -- Движение от джойстика
        if States.joystickActive and joystickDirection.Magnitude > 0.1 then
            -- Вперед/назад (Z компонент)
            if math.abs(joystickDirection.Z) > 0.1 then
                moveVector = moveVector + camera.CFrame.LookVector * joystickDirection.Z
            end
            -- Влево/вправо (X компонент)
            if math.abs(joystickDirection.X) > 0.1 then
                moveVector = moveVector + camera.CFrame.RightVector * joystickDirection.X
            end
        end
        
        -- Подъем/спуск
        if States.upHolding then
            moveVector = moveVector + Vector3.new(0, 1, 0)
        end
        if States.downHolding then
            moveVector = moveVector - Vector3.new(0, 1, 0)
        end
        
        -- Применяем скорость
        if moveVector.Magnitude > 0 then
            bodyVelocity.Velocity = moveVector.Unit * States.flySpeed
        else
            bodyVelocity.Velocity = Vector3.zero
        end
    end)
    
    addConsole("✈️ Полет активирован!", Color3.fromRGB(0, 255, 255))
    addConsole("🎮 Используй джойстик и ▲▼", Color3.fromRGB(255, 255, 0))
end

local function stopMobileFly()
    States.flying = false
    States.upHolding = false
    States.downHolding = false
    
    if flyConnection then
        flyConnection:Disconnect()
        flyConnection = nil
    end
    
    if bodyGyro then
        bodyGyro:Destroy()
        bodyGyro = nil
    end
    
    if bodyVelocity then
        bodyVelocity:Destroy()
        bodyVelocity = nil
    end
    
    local humanoid = getHumanoid()
    if humanoid then
        humanoid.PlatformStand = false
    end
    
    JoystickFrame.Visible = false
    UpButton.Visible = false
    DownButton.Visible = false
    
    addConsole("✈️ Полет отключен", Color3.fromRGB(255, 165, 0))
end

-- Другие функции
local function startNoclip()
    States.noclip = true
    local connection
    connection = runService.Stepped:Connect(function()
        if not States.noclip then connection:Disconnect() return end
        local char = getCharacter()
        if char then
            for _, part in ipairs(char:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide = false end
            end
        end
    end)
    addConsole("👻 Ноклип ON")
end

local function stopNoclip()
    States.noclip = false
    local char = getCharacter()
    if char then
        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = true end
        end
    end
    addConsole("👻 Ноклип OFF")
end

local function startGodMode()
    States.godMode = true
    spawn(function()
        while States.godMode do
            local humanoid = getHumanoid()
            if humanoid then humanoid.Health = humanoid.MaxHealth end
            wait(0.1)
        end
    end)
    addConsole("🛡️ God ON")
end

local function stopGodMode()
    States.godMode = false
    addConsole("🛡️ God OFF")
end

local function toggleInvisibility()
    States.invisible = not States.invisible
    local char = getCharacter()
    if char then
        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.Transparency = States.invisible and 1 or 0
            end
        end
    end
    addConsole(States.invisible and "👁️ Invis ON" or "👁️ Invis OFF")
end

local function startESP()
    States.espEnabled = true
    for _, plr in ipairs(game.Players:GetPlayers()) do
        if plr ~= player and plr.Character then
            local hl = Instance.new("Highlight")
            hl.Name = "ESP"
            hl.FillColor = Color3.fromRGB(255, 0, 0)
            hl.Parent = plr.Character
        end
    end
    addConsole("👁️ ESP ON")
end

local function stopESP()
    States.espEnabled = false
    for _, plr in ipairs(game.Players:GetPlayers()) do
        if plr.Character then
            local hl = plr.Character:FindFirstChild("ESP")
            if hl then hl:Destroy() end
        end
    end
    addConsole("👁️ ESP OFF")
end

local function teleportToPlayer(targetName)
    for _, plr in ipairs(game.Players:GetPlayers()) do
        if plr.Name:lower():find(targetName:lower()) and plr.Character then
            local root = plr.Character:FindFirstChild("HumanoidRootPart")
            if root then
                local myRoot = getRootPart()
                if myRoot then
                    myRoot.CFrame = root.CFrame + Vector3.new(0, 3, 0)
                    addConsole("📍 ТП к " .. plr.Name)
                    return
                end
            end
        end
    end
end

local function setTime(time)
    lighting.ClockTime = time
    addConsole("⏰ Время: " .. time)
end

local function fullBright()
    States.fullBright = not States.fullBright
    if States.fullBright then
        lighting.Brightness = 2
        lighting.ClockTime = 14
        lighting.FogEnd = 100000
        lighting.GlobalShadows = false
    else
        lighting.Brightness = 1
        lighting.GlobalShadows = true
    end
    addConsole(States.fullBright and "💡 Яркость ON" or "💡 Яркость OFF")
end

local function xrayMode()
    States.xrayEnabled = not States.xrayEnabled
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and not obj.Parent:FindFirstChildOfClass("Humanoid") then
            obj.LocalTransparencyModifier = States.xrayEnabled and 0.7 or 0
        end
    end
    addConsole(States.xrayEnabled and "🔍 X-Ray ON" or "🔍 X-Ray OFF")
end

local function setFOV(fov)
    States.fov = fov
    workspace.CurrentCamera.FieldOfView = fov
    addConsole("📷 FOV: " .. fov)
end

local function killAll()
    local myChar = getCharacter()
    for _, plr in ipairs(game.Players:GetPlayers()) do
        if plr.Character and plr.Character ~= myChar then
            local hum = plr.Character:FindFirstChildOfClass("Humanoid")
            if hum then hum.Health = 0 end
        end
    end
    addConsole("☠️ Все убиты")
end

local function serverHop()
    local servers = {}
    pcall(function()
        local data = httpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?limit=100"))
        if data.data then
            for _, s in ipairs(data.data) do
                if s.playing < s.maxPlayers then
                    table.insert(servers, s.id)
                end
            end
        end
    end)
    if #servers > 0 then
        teleportService:TeleportToPlaceInstance(game.PlaceId, servers[math.random(1, #servers)], player)
    end
end

-- Команды
local function executeCommand(cmd)
    if not cmd or cmd == "" then return end
    
    local parts = {}
    for part in cmd:gmatch("%S+") do
        table.insert(parts, part:lower())
    end
    
    local main = parts[1]
    local args = {select(2, unpack(parts))}
    
    if main == ";fly" then
        if args[1] then startMobileFly(tonumber(args[1])) else startMobileFly(50) end
    elseif main == ";unfly" then stopMobileFly()
    elseif main == ";noclip" then startNoclip()
    elseif main == ";clip" then stopNoclip()
    elseif main == ";god" then startGodMode()
    elseif main == ";ungod" then stopGodMode()
    elseif main == ";invis" then toggleInvisibility()
    elseif main == ";esp" then startESP()
    elseif main == ";unesp" then stopESP()
    elseif main == ";tp" and args[1] then teleportToPlayer(args[1])
    elseif main == ";killall" then killAll()
    elseif main == ";time" and args[1] then setTime(tonumber(args[1]))
    elseif main == ";fullbright" then fullBright()
    elseif main == ";xray" then xrayMode()
    elseif main == ";fov" and args[1] then setFOV(tonumber(args[1]))
    elseif main == ";serverhop" then serverHop()
    elseif main == ";help" then
        addConsole(";fly | ;unfly | ;noclip | ;god | ;invis | ;esp | ;tp | ;killall | ;time | ;fullbright | ;xray | ;fov")
    end
end

CommandInput.FocusLost:Connect(function(enter)
    if enter then
        executeCommand(CommandInput.Text)
        CommandInput.Text = ""
    end
end)

