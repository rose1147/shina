-- Джойстик переменные
local joystickTouches = {}
local joystickCenter = Vector2.zero
local joystickDirection = Vector3.zero
local joystickRadius = 75

-- Обработка касаний джойстика
local function getTouchPosition(touch)
    return Vector2.new(touch.Position.X, touch.Position.Y)
end

JoystickFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        -- Сохраняем касание
        joystickTouches[input] = true
        
        if not States.joystickActive then
            States.joystickActive = true
            joystickCenter = getTouchPosition(input)
            
            -- Перемещаем джойстик к месту касания
            JoystickFrame.Position = UDim2.new(0, joystickCenter.X - 75, 0, joystickCenter.Y - 75)
            JoystickStick.Position = UDim2.new(0.5, -25, 0.5, -25)
        end
    end
end)

JoystickFrame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch and joystickTouches[input] then
        local touchPos = getTouchPosition(input)
        local delta = touchPos - joystickCenter
        
        -- Ограничение радиуса
        if delta.Magnitude > joystickRadius then
            delta = delta.Unit * joystickRadius
        end
        
        -- Обновление позиции стика
        JoystickStick.Position = UDim2.new(0.5, delta.X, 0.5, delta.Y)
        
        -- Преобразование в 3D направление (инвертируем Y)
        joystickDirection = Vector3.new(
            delta.X / joystickRadius,
            0,
            -delta.Y / joystickRadius
        )
    end
end)

JoystickFrame.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        joystickTouches[input] = nil
        
        -- Проверяем, остались ли еще касания
        local hasTouches = false
        for _ in pairs(joystickTouches) do
            hasTouches = true
            break
        end
        
        if not hasTouches then
            States.joystickActive = false
            joystickDirection = Vector3.zero
            JoystickStick.Position = UDim2.new(0.5, -25, 0.5, -25)
        end
    end
end)

