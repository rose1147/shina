        addButton("👁️ ESP", function() if not States.espEnabled then startESP() else stopESP() end end, Color3.fromRGB(0, 255, 100))
        addButton("☠️ Kill All", killAll)
        
        -- Слайдер скорости
        local sliderFrame = Instance.new("Frame")
        sliderFrame.Parent = ContentFrame
        sliderFrame.BackgroundTransparency = 1
        sliderFrame.Size = UDim2.new(1, -10, 0, 50)
        sliderFrame.Position = UDim2.new(0, 5, 0, y)
        
        local sliderLabel = Instance.new("TextLabel")
        sliderLabel.Parent = sliderFrame
        sliderLabel.BackgroundTransparency = 1
        sliderLabel.Size = UDim2.new(1, 0, 0, 15)
        sliderLabel.Text = "Скорость полета: 50"
        sliderLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        sliderLabel.TextSize = 10
        
        local slider = Instance.new("TextBox")
        slider.Parent = sliderFrame
        slider.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        slider.Size = UDim2.new(1, 0, 0, 25)
        slider.Position = UDim2.new(0, 0, 0, 20)
        slider.Text = "50"
        slider.TextColor3 = Color3.fromRGB(255, 255, 255)
        slider.TextSize = 10
        
        slider.FocusLost:Connect(function()
            local val = tonumber(slider.Text)
            if val and val > 0 then
                States.flySpeed = val
                sliderLabel.Text = "Скорость полета: " .. val
            end
        end)
        y = y + 55
    elseif currentTab == 2 then
        addButton("💡 Full Bright", fullBright)
        addButton("🔍 X-Ray", xrayMode)
        addButton("⏰ День", function() setTime(12) end, Color3.fromRGB(255, 200, 0))
        addButton("🌙 Ночь", function() setTime(0) end, Color3.fromRGB(50, 50, 150))
        
        local fovFrame = Instance.new("Frame")
        fovFrame.Parent = ContentFrame
        fovFrame.BackgroundTransparency = 1
        fovFrame.Size = UDim2.new(1, -10, 0, 50)
        fovFrame.Position = UDim2.new(0, 5, 0, y)
        
        local fovLabel = Instance.new("TextLabel")
        fovLabel.Parent = fovFrame
        fovLabel.BackgroundTransparency = 1
        fovLabel.Size = UDim2.new(1, 0, 0, 15)
        fovLabel.Text = "FOV: 70"
        fovLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        fovLabel.TextSize = 10
        
        local fovInput = Instance.new("TextBox")
        fovInput.Parent = fovFrame
        fovInput.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        fovInput.Size = UDim2.new(1, 0, 0, 25)
        fovInput.Position = UDim2.new(0, 0, 0, 20)
        fovInput.Text = "70"
        fovInput.TextColor3 = Color3.fromRGB(255, 255, 255)
        fovInput.TextSize = 10
        
        fovInput.FocusLost:Connect(function()
            local val = tonumber(fovInput.Text)
            if val and val >= 30 and val <= 120 then
                setFOV(val)
                fovLabel.Text = "FOV: " .. val
            end
        end)
        y = y + 55
    elseif currentTab == 3 then
        for _, plr in ipairs(game.Players:GetPlayers()) do
            if plr ~= player then
                addButton("👤 " .. plr.Name, function() teleportToPlayer(plr.Name) end, Color3.fromRGB(40, 40, 40))
            end
        end
    elseif currentTab == 4 then
        addButton("💾 Сохранить позицию", function()
            local root = getRootPart()
            if root then
                States.teleportLocations["pos" .. #States.teleportLocations + 1] = root.Position
                addConsole("💾 Сохранено")
            end
        end)
        addButton("🌐 Server Hop", serverHop, Color3.fromRGB(0, 200, 200))
        addButton("🔄 Rejoin", function() teleportService:Teleport(game.PlaceId, player) end, Color3.fromRGB(200, 100, 0))
    end
    
    ContentFrame.CanvasSize = UDim2.new(0, 0, 0, y + 20)
end

-- Инициализация
updateContent()
addConsole("✅ Шина Mobile v2.2 готов!")

